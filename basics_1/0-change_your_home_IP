#!/usr/bin/env bash
# Change your home IP
set -euo pipefail

if ! grep -q '^127\.0\.0\.2[[:space:]]\+localhost$' /etc/hosts; then
	sed -i '1i127.0.0.2 localhost' /etc/hosts
fi

if grep -q '^8\.8\.8\.8[[:space:]]\+facebook\.com$' /etc/hosts; then
	:
else
	printf '%s\n' '8.8.8.8 facebook.com' >> /etc/hosts
fi