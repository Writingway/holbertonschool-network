#!/usr/bin/env bash
# Change your home IP
set -euo pipefail

cp /etc/hosts /tmp/hosts.$$
sed 's/^127\.0\.0\.1 localhost/127.0.0.2 localhost/' /tmp/hosts.$$ > /tmp/hosts.$$.tmp
sed '/facebook\.com/d' /tmp/hosts.$$.tmp > /tmp/hosts.$$.tmp2
echo '8.8.8.8 facebook.com' >> /tmp/hosts.$$.tmp2
cp /tmp/hosts.$$.tmp2 /etc/hosts